{
  "version": "1.0.0",
  "tasks": {
    "dev": "deno run --allow-net --allow-env --allow-read --watch src/index.ts",
    "start": "deno run --allow-net --allow-env --allow-read src/index.ts",
    "test": "deno test --allow-net --allow-env --allow-read"
  },
  "imports": {
    "hono": "jsr:@hono/hono@4.11.9",
    "hono/cors": "jsr:@hono/hono@4.11.9/cors",
    "hono/secure-headers": "jsr:@hono/hono@4.11.9/secure-headers",
    "@std/assert": "jsr:@std/assert@^1",
    "@std/testing": "jsr:@std/testing@^1"
  },
  "compilerOptions": {
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  }
}
