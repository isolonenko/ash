# TURN server config (optional — needed when STUN-only ICE fails,
# e.g. symmetric NAT, same-machine testing with mDNS, etc.)
#
# Supports any TURN provider. Examples:
#   - metered.ca free tier: https://www.metered.ca/stun-turn
#   - Cloudflare Calls TURN: https://developers.cloudflare.com/calls/turn/
#   - Self-hosted coturn
#
# Multiple URLs can be comma-separated in VITE_TURN_URL:
#   VITE_TURN_URL=turn:relay.metered.ca:80,turn:relay.metered.ca:443:transport=tcp

VITE_TURN_URL=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=
